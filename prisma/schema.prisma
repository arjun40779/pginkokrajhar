generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  mobile    String
  email     String?  @unique
  role      Role     @default(TENANT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant?

  @@index([mobile])
  @@map("users")
}

model PG {
  id                  String             @id @default(uuid())
  name                String
  slug                String             @unique
  description         String?
  isActive            Boolean            @default(true)
  status              PGStatus           @default(ACTIVE)
  address             String
  area                String
  city                String
  state               String
  pincode             String
  latitude            Float?
  longitude           Float?
  ownerName           String
  ownerPhone          String
  ownerEmail          String?
  alternatePhone      String?
  startingPrice       Decimal
  securityDeposit     Decimal
  brokerageCharges    Decimal?           @default(0)
  totalRooms          Int
  availableRooms      Int
  sanityDocumentId    String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  bookings            Booking[]
  inquiries           Inquiry[]
  rooms               Room[]

  @@index([status, createdAt])
  @@index([sanityDocumentId])
  @@map("pgs")
}

model Room {
  id                  String           @id @default(uuid())
  roomNumber          String
  slug                String           @unique
  description         String?
  isActive            Boolean          @default(true)
  roomType            RoomType
  maxOccupancy        Int
  currentOccupancy    Int              @default(0)
  floor               Int
  roomSize            Float?
  hasBalcony          Boolean          @default(false)
  hasAttachedBath     Boolean          @default(false)
  hasAC               Boolean          @default(false)
  hasFan              Boolean          @default(true)
  windowDirection     WindowDirection?
  monthlyRent         Decimal
  securityDeposit     Decimal
  maintenanceCharges  Decimal?         @default(0)
  electricityIncluded Boolean          @default(true)
  availabilityStatus  RoomStatus       @default(AVAILABLE)
  availableFrom       DateTime?
  pgId                String
  featured            Boolean          @default(false)
  sanityDocumentId    String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  bookings            Booking[]
  pg                  PG               @relation(fields: [pgId], references: [id], onDelete: Cascade)
  tenants             Tenant[]

  @@unique([pgId, roomNumber])
  @@index([pgId, isActive, roomNumber])
  @@index([pgId, availabilityStatus, monthlyRent])
  @@index([availabilityStatus])
  @@index([sanityDocumentId])
  @@map("rooms")
}

model Tenant {
  id               String     @id @default(uuid())
  name             String
  phone            String
  email            String?
  occupation       String?
  emergencyContact Json?
  moveInDate       DateTime
  moveOutDate      DateTime?
  isActive         Boolean    @default(true)
  rentAmount       Int
  rentStatus       RentStatus @default(PENDING)
  userId           String     @unique
  roomId           String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  payments         Payment[]
  room             Room       @relation(fields: [roomId], references: [id])
  user             User       @relation(fields: [userId], references: [id])

  @@index([roomId, isActive])
  @@index([phone, isActive])
  @@index([isActive, createdAt])
  @@map("tenants")
}

model Booking {
  id              String        @id @default(uuid())
  customerName    String
  customerPhone   String
  customerEmail   String?
  checkInDate     DateTime
  checkOutDate    DateTime?
  status          BookingStatus @default(PENDING)
  monthlyRent     Decimal
  securityDeposit Decimal
  totalAmount     Decimal
  paidAmount      Decimal       @default(0)
  pgId            String?
  roomId          String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  pg              PG?           @relation(fields: [pgId], references: [id])
  room            Room?         @relation(fields: [roomId], references: [id])

  @@index([status, createdAt])
  @@index([pgId, status, createdAt])
  @@index([roomId, status, createdAt])
  @@index([customerEmail, createdAt])
  @@map("bookings")
}

model Payment {
  id          String        @id @default(uuid())
  tenantId    String
  amount      Decimal
  status      PaymentStatus @default(PENDING)
  paymentDate DateTime?
  dueDate     DateTime
  month       String
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tenant      Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, month])
  @@index([tenantId, dueDate])
  @@index([status, paymentDate])
  @@map("payments")
}

model Inquiry {
  id        String        @id @default(uuid())
  name      String
  phone     String
  email     String?
  message   String?
  pgId      String?
  status    InquiryStatus @default(NEW)
  source    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  pg        PG?           @relation(fields: [pgId], references: [id])

  @@index([status, createdAt])
  @@index([pgId, status, createdAt])
  @@map("inquiries")
}

enum Role {
  ADMIN
  TENANT
  OWNER
}

enum PGStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum RoomType {
  SINGLE
  DOUBLE
  TRIPLE
  DORMITORY
}

enum WindowDirection {
  NORTH
  SOUTH
  EAST
  WEST
  NORTHEAST
  NORTHWEST
  SOUTHEAST
  SOUTHWEST
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  RESERVED
  VACANT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum RentStatus {
  PAID
  PENDING
  OVERDUE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum InquiryStatus {
  NEW
  CONTACTED
  CONVERTED
  CLOSED
}
